# Bu dosyayı `keystore.properties` olarak kopyalayıp gerçek değerlerle doldurun.
# `keystore.properties` .gitignore'da — asla commit'lenmez.
#
# Upload keystore üretimi (bkz. android/RELEASE.md):
#   keytool -genkeypair -v -keystore upload-keystore.jks -alias cvdoktoru-upload \
#     -keyalg RSA -keysize 2048 -validity 10000

storeFile=/mutlak/yol/upload-keystore.jks
storePassword=degistirin
keyAlias=cvdoktoru-upload
keyPassword=degistirin
