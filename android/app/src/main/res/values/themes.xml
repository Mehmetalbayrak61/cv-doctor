<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.CvDoktoru" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="android:statusBarColor" tools:targetApi="21">@color/brand_primary</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <!-- MainActivity, onCreate() içinde installSplashScreen() çağırıp hemen ardından
         Theme.CvDoktoru'ya geçer (core-splashscreen resmi kullanım deseni). -->
    <style name="Theme.CvDoktoru.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.CvDoktoru</item>
    </style>
</resources>
