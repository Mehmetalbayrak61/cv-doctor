# development | staging | production
# production'da SECRET_KEY/OPENAI_API_KEY/SMTP_HOST eksikse veya STORAGE_BACKEND=s3
# iken S3_BUCKET boşsa uygulama başlangıçta hemen hata verir (bkz. app/core/config.py).
ENVIRONMENT=development

# docker-compose.yml içindeki servis ile eşleşir
# (5433 kullanılıyor: bazı makinelerde 5432 zaten yerel bir PostgreSQL kurulumu tarafından kullanılıyor olabilir)
DATABASE_URL=postgresql+asyncpg://cvdoktor:cvdoktor@localhost:5433/cvdoktor

SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=["http://localhost:5173"]
# Doğrulama/şifre sıfırlama e-postalarındaki linkler bu adrese göre oluşturulur.
FRONTEND_URL=http://localhost:5173

# Faz 4'te AI özelliklerini test etmek için gereklidir
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Dosya Depolama (Faz 7) ---
# "local" (varsayılan, dev) veya "s3" (S3/R2/Supabase Storage — hepsi S3 API uyumlu
# olduğu için tek implementasyon yeterli, bkz. app/storage/s3_storage.py)
STORAGE_BACKEND=local
STORAGE_DIR=storage_data
MAX_CV_UPLOAD_SIZE_MB=10

# STORAGE_BACKEND=s3 iken kullanılır:
S3_BUCKET=
# Gerçek AWS S3 için boş bırakın.
# Cloudflare R2 örneği: https://<account_id>.r2.cloudflarestorage.com
# Supabase Storage örneği: https://<project_ref>.supabase.co/storage/v1/s3
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- E-posta (Faz 7) ---
# SMTP_HOST boş bırakılırsa e-postalar gönderilmez, bunun yerine ConsoleEmailSender
# içeriği (doğrulama/sıfırlama linki dahil) uygulama loguna yazar (yalnızca dev için).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=no-reply@cvdoktoru.app
EMAIL_FROM_NAME=CV Doktoru

# --- Rate Limiting (Faz 7) ---
# /auth/register, /auth/login, /auth/verify-email, /auth/resend-verification,
# /auth/forgot-password, /auth/reset-password için IP başına 15 dakikalık deneme limiti.
# Tek sunuculu (self-hosted VPS) deploy için yeterlidir; birden fazla backend
# instance'ına ölçeklenirse in-memory yerine Redis tabanlı bir limitleyiciye geçilmeli.
AUTH_RATE_LIMIT_PER_15_MIN=10
# X-Forwarded-For'a güvenilecek hop sayısı. 0 (varsayılan) = asla güvenilmez,
# her zaman ham TCP bağlantısının IP'si kullanılır (header spoofing'e karşı
# güvenli). Railway/Render/Fly.io veya tek katmanlı bir Nginx/Caddy reverse proxy
# arkasında 1 yapın — güvenilir proxy gerçek istemci IP'sini her zaman header'ın
# SONUNA ekler, bu yüzden yalnızca sondan bu kadar hop'a güvenilir.
TRUSTED_PROXY_COUNT=0
